<%- include('../../partials/header', {
  title, provider, sdkVersion, currentProductKey, currentSdkVersion,
  sidebarProducts, showSidebar,
}) %>

<div class="sandbox-page">
  <div class="sandbox-header">
    <span class="provider-badge badge-paypal">PayPal · JSSDK v6 · ECM</span>
    <h1><%= title %></h1>
    <p>Express Checkout Mark — merchant-prefilled shipping, buyer confirms in PayPal sheet.</p>
  </div>

  <div class="sandbox-card">
    <div class="amount-row">
      <div class="currency-group">
        <label class="field-label" for="demo-currency">Currency</label>
        <select id="demo-currency" class="currency-select" aria-label="Select currency">
          <% supportedCurrencies.forEach(function(c) { %>
            <option value="<%= c %>" <%= c === currency ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="amount-group">
        <label class="field-label" for="demo-amount">Amount</label>
        <div class="amount-input-wrapper">
          <input id="demo-amount" class="amount-input" type="text" inputmode="decimal"
            value="<%= defaultAmount || '100.00' %>" placeholder="0.00"
            aria-label="Payment amount" />
        </div>
      </div>
    </div>
    <div style="margin:12px 0 0">
      <label class="field-label" for="demo-presentation-mode">Presentation Mode</label>
      <select id="demo-presentation-mode" class="currency-select" aria-label="Select presentation mode" style="margin-top:6px">
        <option value="auto">auto</option>
        <option value="payment-handler">payment-handler</option>
        <option value="popup">popup</option>
        <option value="redirect">redirect</option>
        <option value="modal">modal</option>
      </select>
      <p id="demo-presentation-mode-desc" style="font-size:0.78rem;color:#6b7280;margin:6px 0 0;line-height:1.4;min-height:1.4em"></p>
      <p style="font-size:0.72rem;color:#9ca3af;margin:4px 0 0;line-height:1.3">If the selected mode is unavailable, the demo will automatically fall back to the remaining modes in order.</p>
    </div>
    <span class="sandbox-mode-badge" style="display:inline-block;margin-bottom:16px">⚡ Sandbox Mode</span>

    <div id="paypal-button-container" class="sdk-loading">
      <div class="sdk-spinner"></div>
      <span>Loading PayPal...</span>
    </div>

    <div class="result-msg" id="result" role="alert" aria-live="polite"></div>
  </div>
</div>

<script>
  window.DEMO = {
    clientId:   '<%= clientId %>',
    components: ['paypal-payments'],
    pageType:   'checkout',
    urls: {
      createOrder:  '/paypal/jssdk-v6/api/paypal-ecm/create-order',
      captureOrder: '/paypal/jssdk-v6/api/paypal-ecm/capture-order',
    },
  }
</script>
<script src="/js/paypal/jssdk-v6/init.js"></script>
<script src="/js/paypal/jssdk-v6/paypal-ecm.js"></script>
<script defer src="https://www.sandbox.paypal.com/web-sdk/v6/core"></script>

<%- include('../../partials/footer', { showSidebar }) %>
