<%- include('../../partials/header', {
  title, provider, sdkVersion, currentProductKey, currentSdkVersion,
  sidebarProducts, showSidebar, sdkUrl
}) %>

<style>
  .sm-control-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: flex-end;
    margin-bottom: 12px;
  }
  .sm-merchant-group,
  .sm-decline-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .sm-decline-select {
    padding: 6px 10px;
    border: 1px solid var(--border, #ddd);
    border-radius: 6px;
    background: var(--bg-card, #fff);
    color: var(--text, #111);
    font-size: 14px;
    cursor: pointer;
    min-width: 180px;
  }
  .sm-subscribe-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    font-size: 14px;
  }
  .sm-subscribe-row input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
  }
  .sm-info-notice {
    margin: 0 0 14px;
    padding: 10px 14px;
    background: #eef4ff;
    border-left: 3px solid #4a90e2;
    border-radius: 4px;
    font-size: 13px;
    color: var(--text-secondary, #555);
    line-height: 1.5;
  }
</style>

<div class="sandbox-page">
  <div class="sandbox-header">
    <span class="provider-badge badge-paypal">PayPal · JSSDK v5 · Shipping Module</span>
    <h1><%= title %></h1>
  </div>

  <div class="sandbox-card">
    <div class="sm-control-row">
      <div class="sm-merchant-group">
        <label class="field-label" for="demo-merchant">Merchant</label>
        <select id="demo-merchant" class="currency-select" aria-label="Select merchant">
          <option value="cn" <%= merchant === 'cn' ? 'selected' : '' %>>CN</option>
          <option value="us" <%= merchant === 'us' ? 'selected' : '' %>>US</option>
        </select>
      </div>
      <div class="currency-group">
        <label class="field-label" for="demo-currency">Currency</label>
        <select id="demo-currency" class="currency-select" aria-label="Select currency">
          <% var _cur = currency || 'USD' %>
          <% ['USD','EUR','GBP','CAD','AUD','BRL','CHF','CZK','DKK','HKD','HUF','ILS','JPY','MXN','NOK','NZD','PHP','PLN','SEK','SGD','THB','TWD','KRW','CLP','SAR','UYU','COP','IDR','PEN','AED'].forEach(function(c) { %>
            <option value="<%= c %>" <%= _cur === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="amount-group">
        <label class="field-label" for="demo-amount">Amount</label>
        <div class="amount-input-wrapper">
          <input id="demo-amount" class="amount-input" type="text" inputmode="decimal"
            value="<%= defaultAmount || '100.00' %>" placeholder="0.00"
            aria-label="Payment amount" />
        </div>
      </div>
    </div>

    <div class="sm-subscribe-row">
      <input type="checkbox" id="subscribe-options" checked aria-label="Subscribe to SHIPPING_OPTIONS events" />
      <label for="subscribe-options">
        Subscribe <code>SHIPPING_OPTIONS</code>
        <span style="color:var(--text-secondary,#888);font-size:12px;">(<code>SHIPPING_ADDRESS</code> always on)</span>
      </label>
    </div>

    <div class="sm-control-row">
      <div class="sm-decline-group">
        <label class="field-label" for="simulate-decline">Simulate decline</label>
        <select id="simulate-decline" class="sm-decline-select" aria-label="Simulate decline scenario">
          <option value="none">none</option>
          <option value="COUNTRY_ERROR">COUNTRY_ERROR</option>
          <option value="ZIP_ERROR">ZIP_ERROR</option>
          <option value="STATE_ERROR">STATE_ERROR</option>
          <option value="ADDRESS_ERROR">ADDRESS_ERROR</option>
          <option value="METHOD_UNAVAILABLE">METHOD_UNAVAILABLE</option>
          <option value="STORE_UNAVAILABLE">STORE_UNAVAILABLE</option>
        </select>
      </div>
    </div>

    <div class="amount-error" id="amount-error" role="alert"></div>
    <span class="sandbox-mode-badge" style="display:inline-block;margin-bottom:14px">⚡ Sandbox Mode</span>

    <div class="sm-info-notice" role="note">
      <strong>Address simulation tips (enter on the review page):</strong>
      <ul style="margin:6px 0 0 16px;padding:0;">
        <li>State <strong>NY</strong> — applies a $10 SUMMER_SALE discount to the order total (US merchant only)</li>
        <li>State <strong>DC</strong> — triggers STATE_ERROR (address rejected by server)</li>
      </ul>
    </div>

    <div id="paypal-button-container" class="sdk-loading">
      <div class="sdk-spinner"></div>
      <span>Loading PayPal...</span>
    </div>

    <div class="result-msg" id="result" role="alert" aria-live="polite"></div>
  </div>
</div>

<script>
  window.DEMO = {
    urls: {
      createOrder:  '/paypal/jssdk-v5/api/shipping-module/create-order',
      captureOrder: '/paypal/jssdk-v5/api/shipping-module/capture-order',
    },
    merchant: '<%= merchant %>',
    currency: '<%= currency %>',
  }
</script>
<script src="/js/paypal/jssdk-v5/shipping-module.js"></script>

<%- include('../../partials/footer', { showSidebar }) %>
