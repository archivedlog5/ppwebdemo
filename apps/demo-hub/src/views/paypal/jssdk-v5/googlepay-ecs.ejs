<%- include('../../partials/header', {
  title, provider, sdkVersion, currentProductKey, currentSdkVersion,
  sidebarProducts, showSidebar, sdkUrl,
  extraScripts: [{ url: 'https://pay.google.com/gp/p/js/pay.js' }]
}) %>

<div class="sandbox-page">
  <div class="sandbox-header">
    <span class="provider-badge badge-paypal">PayPal · JSSDK v5 · Google Pay</span>
    <h1><%= title %></h1>
    <p>Google Pay via PayPal. Requires Chrome + Google Pay card.</p>
  </div>
  <div class="sandbox-card">
    <div class="amount-display">
      <div class="amount-label">Test Amount</div>
      <div class="amount-value">$100.00</div>
      <span class="sandbox-mode-badge">⚡ Sandbox Mode</span>
    </div>
    <div id="paypal-button-container" class="sdk-loading">
      <div class="sdk-spinner"></div><span>Loading Google Pay...</span>
    </div>
    <div class="result-msg" id="result" role="alert" aria-live="polite"></div>
  </div>
</div>

<script>
  window.DEMO = {
    urls: {
      createOrder:  '/paypal/jssdk-v5/api/googlepay-ecs/create-order',
      captureOrder: '/paypal/jssdk-v5/api/googlepay-ecs/capture-order',
    }
  }
</script>
<%# googlepay.js 待实现 %>

<%- include('../../partials/footer', { showSidebar }) %>
