<%- include('../../partials/header', {
  title, provider, sdkVersion, currentProductKey, currentSdkVersion,
  sidebarProducts, showSidebar, sdkUrl
}) %>

<div class="sandbox-page">
  <div class="sandbox-header">
    <span class="provider-badge badge-paypal">PayPal · JSSDK v5 · ACDC</span>
    <h1><%= title %></h1>
    <p>Advanced Credit/Debit Card — hosted card input fields</p>
  </div>
  <div class="sandbox-card">
    <div class="amount-display">
      <div class="amount-label">Test Amount</div>
      <div class="amount-value">$100.00</div>
      <span class="sandbox-mode-badge">⚡ Sandbox Mode</span>
    </div>

    <div class="field-group">
      <label class="field-label" for="card-number-container">Card Number</label>
      <div class="field-host sdk-loading" id="card-number-container">
        <div class="sdk-spinner"></div><span>Loading...</span>
      </div>
    </div>
    <div class="field-row">
      <div class="field-group">
        <label class="field-label">Expiry</label>
        <div class="field-host" id="card-expiry-container"></div>
      </div>
      <div class="field-group">
        <label class="field-label">CVV</label>
        <div class="field-host" id="card-cvv-container"></div>
      </div>
    </div>
    <div class="field-group">
      <label class="field-label">Name on Card</label>
      <div class="field-host" id="card-name-container"></div>
    </div>

    <button id="acdc-pay-btn" class="pay-btn pay-btn-paypal" type="button">Pay $1.00</button>
    <div class="result-msg" id="result" role="alert" aria-live="polite"></div>
    <div class="test-hint">Test card: <strong>4111 1111 1111 1111</strong> · Any future date · Any CVV</div>
  </div>
</div>

<script>
  window.DEMO = {
    urls: {
      createOrder:  '/paypal/jssdk-v5/api/acdc/create-order',
      captureOrder: '/paypal/jssdk-v5/api/acdc/capture-order',
    }
  }
</script>
<script src="/js/paypal/jssdk-v5/acdc.js"></script>

<%- include('../../partials/footer', { showSidebar }) %>
