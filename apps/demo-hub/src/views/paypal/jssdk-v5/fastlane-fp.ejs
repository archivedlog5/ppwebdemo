<%- include('../../partials/header', {
  title, provider, sdkVersion, currentProductKey, currentSdkVersion,
  sidebarProducts, showSidebar
}) %>

<style>
/* ── Fastlane FP — page-scoped styles (copied from fastlane-pui, extended to 4 steps) ── */

/* Amount row */
.fl-amount-row {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: var(--sp-3) var(--sp-4);
  margin-bottom: var(--sp-5);
}
.fl-amount-label {
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--fg-subtle);
  flex-shrink: 0;
}
.fl-amount-cur {
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: 700;
  color: var(--fg-subtle);
  margin-right: 1px;
}
.fl-amount-input {
  background: transparent;
  border: none;
  outline: none;
  font-family: var(--font-mono);
  font-size: 22px;
  font-weight: 700;
  color: var(--fg);
  width: 100%;
  min-width: 0;
  padding: 0;
  -moz-appearance: textfield;
}
.fl-amount-input::-webkit-outer-spin-button,
.fl-amount-input::-webkit-inner-spin-button { -webkit-appearance: none; }

/* Steps */
.fl-steps { display: flex; flex-direction: column; gap: var(--sp-2); }

.fl-step {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: border-color 150ms ease, box-shadow 150ms ease;
}
.fl-step.fl-active {
  border-color: var(--border-hi);
  box-shadow: 0 2px 12px rgba(0,0,0,0.25);
}

/* Header */
.fl-step__hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-4) var(--sp-5);
  gap: var(--sp-3);
}
.fl-step.fl-active .fl-step__hd {
  border-bottom: 1px solid var(--border);
}
.fl-step__hd-left {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  flex: 1;
  min-width: 0;
}

/* Step circle */
.fl-step__num {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 1.5px solid var(--border-hi);
  background: var(--surface2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  color: var(--fg-muted);
  flex-shrink: 0;
  transition: all 150ms ease;
}
.fl-step.fl-active .fl-step__num {
  border-color: var(--accent);
  background: var(--accent);
  color: #021a0e;
}
.fl-step.fl-visited:not(.fl-active) .fl-step__num {
  border-color: var(--accent-dim);
  background: rgba(34,197,94,0.1);
  color: var(--accent);
}
/* Number text hidden + checkmark shown when visited */
.fl-step.fl-visited:not(.fl-active) .fl-step__num span { display: none; }
.fl-step.fl-visited:not(.fl-active) .fl-step__num::before { content: '✓'; font-size: 12px; }

/* Title + summary */
.fl-step__meta { flex: 1; min-width: 0; }
.fl-step__title {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--fg-muted);
  transition: color 150ms ease;
}
.fl-step.fl-active .fl-step__title { color: var(--fg); }
.fl-step.fl-visited:not(.fl-active) .fl-step__title { color: var(--fg-muted); }

.fl-step__summary {
  display: none;
  font-family: var(--font-sans);
  font-size: 11px;
  color: var(--fg-subtle);
  margin-top: 3px;
  white-space: pre-line;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
}
.fl-step.fl-visited:not(.fl-active) .fl-step__summary { display: block; }

/* Edit button */
.fl-step__edit {
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  color: var(--fg-subtle);
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.3px;
  padding: 4px 10px;
  cursor: pointer;
  flex-shrink: 0;
  opacity: 0;
  pointer-events: none;
  transition: all 150ms ease;
}
.fl-step.fl-visited:not(.fl-active) .fl-step__edit { opacity: 1; pointer-events: auto; }
/* Payment step: show Edit even when fl-active so member can switch cards */
.fl-step.fl-active.fl-visited .fl-step__edit { opacity: 1; pointer-events: auto; }
.fl-step__edit:hover { border-color: var(--border-hi); color: var(--fg); }

/* Body */
.fl-step__body {
  display: none;
  padding: var(--sp-4) var(--sp-5) var(--sp-5);
}
.fl-step.fl-active .fl-step__body { display: block; }

/* Fields */
.fl-field {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: var(--sp-3);
}
.fl-label {
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.4px;
  text-transform: uppercase;
  color: var(--fg-subtle);
}
.fl-input {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  padding: 10px var(--sp-3);
  color: var(--fg);
  font-family: var(--font-sans);
  font-size: 13px;
  font-weight: 400;
  outline: none;
  transition: border-color 150ms ease, box-shadow 150ms ease;
  min-height: 44px;
  width: 100%;
  box-sizing: border-box;
}
.fl-input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px var(--accent-glow);
}
.fl-input::placeholder { color: var(--fg-subtle); }
.fl-input.input-invalid {
  border-color: var(--error);
  box-shadow: 0 0 0 2px rgba(239,68,68,0.1);
}
.fl-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-2);
}
@media (max-width: 400px) { .fl-row { grid-template-columns: 1fr; } }

/* Watermark */
.fl-watermark { margin-top: var(--sp-2); min-height: 20px; }

/* Checkbox row */
.fl-checkbox-row {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  padding: var(--sp-3);
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  margin-bottom: var(--sp-4);
  cursor: pointer;
}
.fl-checkbox-row input[type=checkbox] {
  width: 16px; height: 16px;
  accent-color: var(--accent);
  cursor: pointer;
  flex-shrink: 0;
}
.fl-checkbox-row label {
  font-family: var(--font-sans);
  font-size: 12px;
  color: var(--fg-muted);
  cursor: pointer;
  line-height: 1.3;
  user-select: none;
}

/* Locked state */
.fl-step:not(.fl-active):not(.fl-visited) .fl-step__num { opacity: 0.35; }
.fl-step:not(.fl-active):not(.fl-visited) .fl-step__title { opacity: 0.4; }

/* CTA button */
.fl-btn {
  width: 100%;
  min-height: 48px;
  background: var(--accent);
  border: none;
  border-radius: var(--r-sm);
  color: #021a0e;
  font-family: var(--font-mono);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.3px;
  cursor: pointer;
  margin-top: var(--sp-4);
  transition: filter 150ms ease, transform 80ms ease;
}
.fl-btn:hover:not(:disabled) { filter: brightness(1.08); transform: translateY(-1px); }
.fl-btn:active:not(:disabled) { transform: translateY(0); }
.fl-btn:disabled { opacity: 0.35; cursor: not-allowed; }

/* Selected card (member has saved card) */
.fl-selected-card {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--fg-muted);
  padding: var(--sp-3);
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  margin-bottom: var(--sp-3);
  min-height: 20px;
}

/* Billing step: hidden when member has saved card */
#step-billing[hidden] { display: none; }
</style>

<div class="sandbox-page">
  <div class="sandbox-header">
    <span class="provider-badge badge-paypal">PayPal · JSSDK v5 · Fastlane</span>
    <h1><%= title %></h1>
    <p>Flexible — FastlaneCardComponent + own billing form + 3DS (JSSDK &amp; API flows)</p>
  </div>

  <div class="sandbox-card" style="max-width:480px">

    <!-- Amount (USD locked — Fastlane US only) -->
    <div class="fl-amount-row">
      <span class="fl-amount-label">Total</span>
      <span class="fl-amount-cur">$</span>
      <input id="demo-amount" class="fl-amount-input" type="number"
        step="0.01" min="1" max="30000" value="<%= defaultAmount %>" />
      <span class="fl-amount-cur" style="margin-left:auto">USD</span>
    </div>

    <form id="fl-form" autocomplete="on" novalidate>
      <div class="fl-steps">

        <!-- Step 1: Customer -->
        <div class="fl-step fl-active" id="step-customer">
          <div class="fl-step__hd">
            <div class="fl-step__hd-left">
              <div class="fl-step__num"><span>1</span></div>
              <div class="fl-step__meta">
                <div class="fl-step__title">Customer</div>
                <div class="fl-step__summary" id="customer-summary"></div>
              </div>
            </div>
            <button id="email-edit-button" type="button" class="fl-step__edit">Edit</button>
          </div>
          <div class="fl-step__body">
            <div class="fl-field">
              <label class="fl-label" for="email-input">Email address</label>
              <input id="email-input" name="email" class="fl-input" type="email"
                placeholder="you@example.com" autocomplete="email" required />
            </div>
            <div class="fl-watermark" id="watermark-container"></div>
            <button id="email-submit-button" type="button" class="fl-btn" disabled>Continue</button>
          </div>
        </div>

        <!-- Step 2: Shipping -->
        <div class="fl-step" id="step-shipping">
          <div class="fl-step__hd">
            <div class="fl-step__hd-left">
              <div class="fl-step__num"><span>2</span></div>
              <div class="fl-step__meta">
                <div class="fl-step__title">Shipping</div>
                <div class="fl-step__summary" id="shipping-summary"></div>
              </div>
            </div>
            <button id="shipping-edit-button" type="button" class="fl-step__edit">Edit</button>
          </div>
          <div class="fl-step__body">
            <div class="fl-checkbox-row">
              <input id="shipping-required-checkbox" name="shipping-required" type="checkbox" checked />
              <label for="shipping-required-checkbox">This purchase requires shipping</label>
            </div>
            <div id="shipping-address-fields">
              <div class="fl-row">
                <div class="fl-field">
                  <label class="fl-label" for="given-name">First name</label>
                  <input name="given-name" id="given-name" class="fl-input" placeholder="John" autocomplete="given-name" />
                </div>
                <div class="fl-field">
                  <label class="fl-label" for="family-name">Last name</label>
                  <input name="family-name" id="family-name" class="fl-input" placeholder="Doe" autocomplete="family-name" />
                </div>
              </div>
              <div class="fl-field">
                <label class="fl-label" for="address-line1">Street address</label>
                <input name="address-line1" id="address-line1" class="fl-input" placeholder="123 Main St" autocomplete="address-line1" />
              </div>
              <div class="fl-field">
                <label class="fl-label" for="address-line2">Apt / Suite (optional)</label>
                <input name="address-line2" id="address-line2" class="fl-input" placeholder="Apt 4B" autocomplete="address-line2" />
              </div>
              <div class="fl-row">
                <div class="fl-field">
                  <label class="fl-label" for="address-level2">City</label>
                  <input name="address-level2" id="address-level2" class="fl-input" placeholder="San Francisco" autocomplete="address-level2" />
                </div>
                <div class="fl-field">
                  <label class="fl-label" for="address-level1">State</label>
                  <input name="address-level1" id="address-level1" class="fl-input" placeholder="CA" autocomplete="address-level1" />
                </div>
              </div>
              <div class="fl-row">
                <div class="fl-field">
                  <label class="fl-label" for="postal-code">ZIP code</label>
                  <input name="postal-code" id="postal-code" class="fl-input" placeholder="94105" autocomplete="postal-code" />
                </div>
                <div class="fl-field">
                  <label class="fl-label" for="country">Country</label>
                  <input name="country" id="country" class="fl-input" value="US" autocomplete="country" />
                </div>
              </div>
              <div class="fl-row">
                <div class="fl-field">
                  <label class="fl-label" for="tel-country-code">Dial code</label>
                  <input name="tel-country-code" id="tel-country-code" class="fl-input" value="1" autocomplete="tel-country-code" placeholder="1" />
                </div>
                <div class="fl-field">
                  <label class="fl-label" for="tel-national">Phone</label>
                  <input name="tel-national" id="tel-national" class="fl-input" type="tel" placeholder="555 000 0000" autocomplete="tel-national" />
                </div>
              </div>
            </div><!-- /shipping-address-fields -->
            <button id="shipping-submit-button" type="button" class="fl-btn">Continue</button>
          </div>
        </div>

        <!-- Step 3: Billing (Flexible — hidden for member with saved card) -->
        <div class="fl-step" id="step-billing">
          <div class="fl-step__hd">
            <div class="fl-step__hd-left">
              <div class="fl-step__num"><span>3</span></div>
              <div class="fl-step__meta">
                <div class="fl-step__title">Billing</div>
                <div class="fl-step__summary" id="billing-summary"></div>
              </div>
            </div>
            <button id="billing-edit-button" type="button" class="fl-step__edit">Edit</button>
          </div>
          <div class="fl-step__body">
            <div class="fl-field">
              <label class="fl-label" for="billing-address-line1">Street address</label>
              <input name="billing-address-line1" id="billing-address-line1" class="fl-input" placeholder="123 Main St" autocomplete="billing address-line1" />
            </div>
            <div class="fl-field">
              <label class="fl-label" for="billing-address-line2">Apt / Suite (optional)</label>
              <input name="billing-address-line2" id="billing-address-line2" class="fl-input" placeholder="Apt 4B" autocomplete="billing address-line2" />
            </div>
            <div class="fl-row">
              <div class="fl-field">
                <label class="fl-label" for="billing-address-level2">City</label>
                <input name="billing-address-level2" id="billing-address-level2" class="fl-input" placeholder="San Francisco" autocomplete="billing address-level2" />
              </div>
              <div class="fl-field">
                <label class="fl-label" for="billing-address-level1">State</label>
                <input name="billing-address-level1" id="billing-address-level1" class="fl-input" placeholder="CA" autocomplete="billing address-level1" />
              </div>
            </div>
            <div class="fl-row">
              <div class="fl-field">
                <label class="fl-label" for="billing-postal-code">ZIP code</label>
                <input name="billing-postal-code" id="billing-postal-code" class="fl-input" placeholder="94105" autocomplete="billing postal-code" />
              </div>
              <div class="fl-field">
                <label class="fl-label" for="billing-country">Country</label>
                <input name="billing-country" id="billing-country" class="fl-input" value="US" autocomplete="billing country" />
              </div>
            </div>
            <button id="billing-submit-button" type="button" class="fl-btn">Continue</button>
          </div>
        </div>

        <!-- Step 4: Payment -->
        <div class="fl-step" id="step-payment">
          <div class="fl-step__hd">
            <div class="fl-step__hd-left">
              <div class="fl-step__num"><span>4</span></div>
              <div class="fl-step__meta">
                <div class="fl-step__title">Payment</div>
              </div>
            </div>
            <button id="payment-edit-button" type="button" class="fl-step__edit">Edit</button>
          </div>
          <div class="fl-step__body">
            <!-- 3DS flow selector -->
            <div class="fl-field">
              <label class="fl-label" for="three-ds-flow">3DS Flow</label>
              <select id="three-ds-flow" name="three-ds-flow" class="fl-input">
                <option value="none">None / When Required (direct payment, no 3DS enforcement)</option>
                <option value="jssdk">JSSDK 3DS (client-side, SCA_ALWAYS)</option>
                <option value="api">API 3DS (full-page redirect → return page, SCA_ALWAYS)</option>
              </select>
            </div>
            <!-- Member saved card summary (member-has-card path) -->
            <div id="selected-card" class="fl-selected-card" style="display:none"></div>
            <!-- FastlaneCardComponent mount point (guest / member-no-card) -->
            <div id="card-component"></div>
            <!-- Fastlane watermark (Flexible requirement) -->
            <div id="payment-watermark" class="fl-watermark"></div>
            <button id="checkout-button" type="button" class="fl-btn">Checkout</button>
          </div>
        </div>

      </div><!-- /fl-steps -->
    </form>

    <div id="demo-result" class="result-msg" style="margin-top:var(--sp-4)"></div>

  </div><!-- /sandbox-card -->
</div><!-- /sandbox-page -->

<script>
  window.DEMO = {
    urls: { createOrder: '/paypal/jssdk-v5/api/fastlane-fp/create-order' },
    amount: '<%= defaultAmount %>',
    currency: 'USD'
  };
</script>

<!-- Fastlane SDK — components=fastlane,three-domain-secure; must carry data-sdk-client-token -->
<script
  src="<%= sdkUrl %>"
  data-sdk-client-token="<%= sdkClientToken %>"
  data-sdk-integration-source="developer-studio"></script>
<script src="/js/paypal/jssdk-v5/fastlane-fp.js"></script>

<%- include('../../partials/footer') %>
