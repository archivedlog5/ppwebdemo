<%- include('../../partials/header', {
  title, provider, sdkVersion, currentProductKey, currentSdkVersion,
  sidebarProducts, showSidebar, sdkUrl,
  extraScripts: [{ url: 'https://pay.google.com/gp/p/js/pay.js' }]
}) %>

<div class="sandbox-page">
  <div class="sandbox-header">
    <span class="provider-badge badge-paypal">PayPal · JSSDK v5 · Google Pay</span>
    <h1><%= title %></h1>
    <p>Google Pay via PayPal — Express Checkout Mark. Buyer completes payment inside the Google Pay sheet. Requires Chrome and a Google Pay–linked card.</p>
  </div>
  <div class="sandbox-card">
    <div class="amount-row">
      <div class="currency-group">
        <label class="field-label" for="demo-currency">Currency</label>
        <select id="demo-currency" class="currency-select" aria-label="Select currency">
          <% var _cur = currency || 'USD' %>
          <% ['USD','EUR','GBP','CAD','AUD','BRL','CHF','CZK','DKK','HKD','HUF','ILS','JPY','MXN','NOK','NZD','PHP','PLN','SEK','SGD','THB','TWD','KRW','CLP','SAR','UYU','COP','IDR','PEN','AED'].forEach(function(c) { %>
            <option value="<%= c %>" <%= _cur === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="amount-group">
        <label class="field-label" for="demo-amount">Amount</label>
        <div class="amount-input-wrapper">
          <input id="demo-amount" class="amount-input" type="text" inputmode="decimal"
            value="<%= defaultAmount || '100.00' %>" placeholder="0.00"
            aria-label="Payment amount" />
        </div>
      </div>
      <div class="currency-group">
        <label class="field-label" for="demo-sca">3DS</label>
        <select id="demo-sca" class="currency-select" aria-label="3DS SCA method" style="min-width:160px">
          <option value="SCA_WHEN_REQUIRED" selected>SCA_WHEN_REQUIRED</option>
          <option value="SCA_ALWAYS">SCA_ALWAYS</option>
        </select>
      </div>
    </div>
    <div class="amount-error" id="amount-error" role="alert"></div>
    <span class="sandbox-mode-badge" style="display:inline-block;margin-bottom:16px">⚡ Sandbox Mode</span>

    <div class="field-group">
      <label class="field-label">Shipping Address &amp; Phone <span style="color:var(--fg-muted);font-weight:400">(pre-filled by merchant — not shown in Google Pay sheet)</span></label>
      <div class="field-host" style="padding:10px 12px;color:var(--fg-muted);font-family:var(--font-mono);font-size:13px;line-height:1.6;cursor:default">
        <%= sandboxShipping.name %><br>
        <%= sandboxShipping.addressLine1 %><br>
        <%= sandboxShipping.adminArea2 %>, <%= sandboxShipping.adminArea1 %> <%= sandboxShipping.postalCode %><br>
        <%= sandboxShipping.countryCode %><br>
        <%= sandboxPhone %>
      </div>
    </div>

    <div id="paypal-button-container" class="sdk-loading">
      <div class="sdk-spinner"></div><span>Loading Google Pay...</span>
    </div>

    <div style="margin-top:12px">
      <button id="custom-googlepay-btn" type="button" disabled
        style="width:100%;min-height:44px;padding:0 16px;display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.10);border-radius:8px;color:var(--fg);font-size:13px;font-weight:500;font-family:inherit;letter-spacing:0.02em;cursor:not-allowed;opacity:0.45;transition:background 150ms ease,border-color 150ms ease,transform 100ms ease"
      >Custom GooglePay Button<span style="font-size:10px;padding:2px 5px;background:rgba(234,179,8,0.12);border:1px solid rgba(234,179,8,0.25);border-radius:3px;color:#c97a10;letter-spacing:0.06em;font-weight:600;line-height:1.4">DEMO</span></button>
      <p style="margin:6px 0 0;font-size:11px;color:var(--fg-muted);text-align:center;opacity:.7">Functional but not recommended for production</p>
    </div>

    <div class="result-msg" id="result" role="alert" aria-live="polite"></div>
  </div>
</div>

<script>
  window.DEMO = {
    urls: {
      createOrder:  '/paypal/jssdk-v5/api/googlepay-ecm/create-order',
      getOrder:     '/paypal/jssdk-v5/api/googlepay-ecm/order',
      captureOrder: '/paypal/jssdk-v5/api/googlepay-ecm/capture-order',
    },
    shipping: <%- JSON.stringify(sandboxShipping) %>,
  }
</script>
<script src="/js/paypal/jssdk-v5/googlepay-ecm.js"></script>

<%- include('../../partials/footer', { showSidebar }) %>
