<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>payment_playground — Demo Hub</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/sandbox.css">
  <script src="/js/theme.js"></script>
</head>
<body>

<nav class="topbar" role="navigation" aria-label="Main navigation">
  <a href="/" class="topbar-logo" aria-label="payment_playground home">
    payment<span class="accent">_</span>playground
    <span class="env-badge">SANDBOX</span>
  </a>
  <button class="theme-toggle" id="theme-toggle" type="button">☀ Light</button>
</nav>

<main>
  <section class="home-hero" aria-labelledby="hero-title">
    <div class="home-hero-inner">
      <h1 id="hero-title">
        Payment Integration <span class="accent">Demos</span>
      </h1>
      <p>
        Interactive sandboxes for PayPal, Braintree, Stripe and Adyen.<br>
        Each demo runs real SDK code in sandbox — inspect, test, integrate.
      </p>
      <div class="home-stats" aria-label="Statistics">
        <%
          let totalCount = 0;
          let providerCount = 0;
          Object.values(grouped).forEach(function(sdkVersions) {
            providerCount++;
            Object.values(sdkVersions).forEach(function(products) {
              totalCount += products.length;
            });
          });
        %>
        <div class="stat">
          <span class="stat-value"><%= totalCount %></span>
          <span class="stat-label">Live demos</span>
        </div>
        <div class="stat">
          <span class="stat-value"><%= providerCount %></span>
          <span class="stat-label">Providers</span>
        </div>
        <div class="stat">
          <span class="stat-value">100%</span>
          <span class="stat-label">Sandbox mode</span>
        </div>
      </div>
    </div>
  </section>

  <div class="home-body">

    <% Object.entries(grouped).forEach(function([provider, sdkVersions]) { %>
      <%
        const providerColors = {
          paypal: '#009CDE',
          braintree: '#A855F7',
          stripe: '#818CF8',
          adyen: '#0ABF53'
        };
        const sdkShades = {
          'paypal/jssdk-v5':        '#00B5E2',
          'paypal/jssdk-v6':        '#0070BA',
          'braintree/web-sdk':      '#A855F7',
          'braintree/graphql':      '#7B2FBE',
          'stripe/stripe-js':       '#818CF8',
          'adyen/web-components':   '#22C55E'
        };
        function getShade(prov, sdk) {
          return sdkShades[prov + '/' + sdk] || providerColors[prov] || '#94A3B8';
        }
        const dotColor = providerColors[provider] || '#94A3B8';
        const productCount = Object.values(sdkVersions).reduce(function(acc, ps) { return acc + ps.length; }, 0);
      %>

      <section class="provider-section" aria-labelledby="provider-<%= provider %>" style="--brand: <%= dotColor %>">
        <div class="provider-header"
             role="button"
             tabindex="0"
             aria-expanded="true"
             aria-controls="prov-<%= provider %>-body"
             data-collapse-provider="<%= provider %>">
          <div class="provider-dot" style="background:<%= dotColor %>" aria-hidden="true"></div>
          <span class="provider-name" id="provider-<%= provider %>"><%= provider %></span>
          <span class="provider-count"><%= productCount %> demo<%= productCount !== 1 ? 's' : '' %></span>
          <span class="collapse-icon expanded" aria-hidden="true">&#9658;</span>
        </div>

        <div class="collapsible-body" id="prov-<%= provider %>-body">
          <% Object.entries(sdkVersions).forEach(function([sdkVersion, products]) { %>
            <% const sdkShadeColor = getShade(provider, sdkVersion); %>
            <div class="sdk-section-label"
                 role="button"
                 tabindex="0"
                 aria-expanded="true"
                 aria-controls="sdk-<%= provider %>-<%= sdkVersion %>-body"
                 data-collapse-sdk="<%= provider %>/<%= sdkVersion %>"
                 style="--sdk-shade: <%= sdkShadeColor %>">
              <%= sdkVersion %>
              <span class="collapse-icon expanded" aria-hidden="true">&#9658;</span>
            </div>
            <div class="collapsible-body" id="sdk-<%= provider %>-<%= sdkVersion %>-body">
              <div class="product-grid">
                <% products.forEach(function(product) { %>
                  <a href="/<%= provider %>/<%= sdkVersion %>/<%= product.productKey %>"
                     class="product-card <%= provider %>"
                     style="--sdk-shade: <%= sdkShadeColor %>"
                     aria-label="<%= product.displayName %> demo">
                    <span class="card-tag tag-<%= provider %>"><%= provider %></span>
                    <h3><%= product.displayName %></h3>
                    <p><%= product.description %></p>
                    <div class="card-footer">
                      <span class="card-link" aria-hidden="true">Run demo →</span>
                      <span class="status-dot" title="Live in sandbox" aria-hidden="true"></span>
                    </div>
                  </a>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </section>

    <% }) %>

    <%# Coming soon providers (Stripe, Adyen if not yet in DB) %>
    <% const activeProviders = Object.keys(grouped); %>
    <% const allProviders = ['stripe', 'adyen']; %>
    <% const pendingProviders = allProviders.filter(function(p) { return !activeProviders.includes(p); }); %>

    <% if (pendingProviders.length > 0) { %>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px">
        <% pendingProviders.forEach(function(p) { %>
          <%
            const pendingColors = { stripe: '#818CF8', adyen: '#0ABF53' };
            const pColor = pendingColors[p] || '#94A3B8';
          %>
          <section class="provider-section" style="--brand: <%= pColor %>">
            <div class="provider-header">
              <div class="provider-dot" style="background:<%= pColor %>"></div>
              <span class="provider-name"><%= p %></span>
              <span class="provider-count">Coming soon</span>
            </div>
            <div class="product-grid">
              <div class="product-card <%= p %> coming-soon" aria-disabled="true">
                <span class="card-tag tag-<%= p %>"><%= p %></span>
                <h3>Demos in progress</h3>
                <p>Integration demos for <%= p.charAt(0).toUpperCase() + p.slice(1) %> are coming soon.</p>
                <div class="card-footer">
                  <span style="font-size:10px;color:var(--fg-subtle);font-family:var(--font-mono)">Pending</span>
                </div>
              </div>
            </div>
          </section>
        <% }) %>
      </div>
    <% } %>

  </div>
</main>

<script src="/js/collapse.js"></script>
</body>
</html>
